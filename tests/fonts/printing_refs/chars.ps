%%BeginSetup
% <font> <encoding> font_remap <font>	; from the cookbook
/reencodedict 5 dict def
/font_remap { reencodedict begin
  /newencoding exch def
  /basefont exch def
  /newfont basefont  maxlength dict def
  basefont {
    exch dup dup /FID ne exch /Encoding ne and
	{ exch newfont 3 1 roll put }
	{ pop pop }
    ifelse
  } forall
  newfont /Encoding newencoding put
  /foo newfont definefont	%Leave on stack
  end } def
/n_show { moveto show } bind def
%%IncludeResource: font Times-Bold
/Times-Bold-ISO-8859-1 /Times-Bold findfont ISOLatin1Encoding font_remap definefont
/Times-Bold__12 /Times-Bold-ISO-8859-1 findfont 12 scalefont def
%%EndSetup

